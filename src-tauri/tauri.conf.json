{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pangu Nebula",
  "version": "2.1.0",
  "identifier": "com.pangu.nebula",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pangu Nebula",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* ipc: http://ipc.localhost https://*; img-src 'self' asset: http://asset.localhost data: blob: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Pangu Nebula",
    "category": "Productivity",
    "shortDescription": "AI Agent Desktop Platform",
    "longDescription": "Pangu Nebula — 双主控 + 蜂群 worker + persona 自进化的 AI Agent 桌面平台"
  }
}
