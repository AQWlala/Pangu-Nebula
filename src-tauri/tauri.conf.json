{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pangu Nebula",
  "version": "2.1.10",
  "identifier": "com.pangu.nebula",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pangu Nebula",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/pangu-sidecar/**/*"
    ],
    "externalBin": [],
    "copyright": "© 2026 Pangu Nebula",
    "category": "Productivity",
    "shortDescription": "AI Agent Desktop Platform",
    "longDescription": "Pangu Nebula — AI Agent Desktop Platform with dual-loop + swarm + persona self-evolution",
    "windows": {
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/AQWlala/Pangu-Nebula/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "qVDmGxF8BQvOSHcEx+2+86OkgNAmuKrIwettuqx+rZM="
    }
  }
}
