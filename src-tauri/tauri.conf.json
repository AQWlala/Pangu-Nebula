{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Pangu Nebula",
    "version":  "2.1.1",
    "identifier":  "com.pangu.nebula",
    "build":  {
                  "frontendDist":  "../frontend/dist",
                  "devUrl":  "http://localhost:5173",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Pangu Nebula",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  800,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "decorations":  true,
                                    "center":  true,
                                    "visible":  false
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; connect-src \u0027self\u0027 http://127.0.0.1:* ws://127.0.0.1:* ipc: http://ipc.localhost https://*; img-src \u0027self\u0027 asset: http://asset.localhost data: blob: http://127.0.0.1:*; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; script-src \u0027self\u0027; font-src \u0027self\u0027 data:"
                             },
                "withGlobalTauri":  false
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "resources":  [
                                     "resources/pangu-sidecar/**/*"
                                 ],
                   "externalBin":  [

                                   ],
                   "copyright":  "© 2026 Pangu Nebula",
                   "category":  "Productivity",
                   "shortDescription":  "AI Agent Desktop Platform",
                   "longDescription":  "Pangu Nebula — 双主控 + 蜂群 worker + persona 自进化的 AI Agent 桌面平台",
                   "windows":  {
                                   "wix":  {
                                               "language":  [
                                                                "zh-CN",
                                                                "en-US"
                                                            ]
                                           },
                                   "nsis":  {
                                                "installMode":  "currentUser",
                                                "languages":  [
                                                                  "SimpChinese",
                                                                  "English"
                                                              ],
                                                "displayLanguageSelector":  true
                                            },
                                   "webviewInstallMode":  {
                                                              "type":  "downloadBootstrapper"
                                                          }
                               }
               },
    "plugins":  {
                    "updater":  {
                                    "active":  true,
                                    "endpoints":  [
                                                      "https://github.com/pangu-nebula/pangu-nebula/releases/latest/download/latest.json"
                                                  ],
                                    "dialog":  false,
                                    "pubkey":  "qVDmGxF8BQvOSHcEx+2+86OkgNAmuKrIwettuqx+rZM="
                                }
                }
}
